// POS TAB
// ============================================================
const POSTab = ({
  products, cart, addToCart, removeFromCart, setQty,
  cartTotal, completeSale
}) => {
  const [search, setSearch] = useState('');

  const filtered = products.filter(p =>
    p.name.toLowerCase().includes(search.toLowerCase())
  );

  return (
    <>
      <Bar title="Point of Sale" />

      <div style={{ padding: 16 }}>
        <Field
          placeholder="Search products..."
          value={search}
          onChange={e => setSearch(e.target.value)}
        />

        {/* Products */}
        {filtered.map(p => (
          <div key={p.id} style={S.card}>
            <div style={S.row}>
              <div style={{ flex: 1 }}>
                <div style={{ fontWeight: 800 }}>{p.name}</div>
                <div style={{ color: C.muted }}>
                  {fmt(p.sellingPrice)} · {p.qty} in stock
                </div>
              </div>
              <Btn onClick={() => addToCart(p)}>Add</Btn>
            </div>
          </div>
        ))}

        {/* Cart */}
        <div style={{ marginTop: 20 }}>
          <div style={{ fontWeight: 800 }}>Cart</div>

          {cart.length === 0 && <Empty icon="🛒" msg="No items in cart" />}

          {cart.map(item => (
            <div key={item.pid} style={S.card}>
              <div style={S.row}>
                <div style={{ flex: 1 }}>
                  <div>{item.name}</div>
                  <div>{fmt(item.price)}</div>
                </div>

                <input
                  type="number"
                  value={item.qty}
                  onChange={e => setQty(item.pid, Number(e.target.value))}
                  style={{ width: 60 }}
                />

                <Btn variant="danger" onClick={() => removeFromCart(item.pid)}>X</Btn>
              </div>
            </div>
          ))}

          {cart.length > 0 && (
            <>
              <div style={{ fontWeight: 800, marginTop: 10 }}>
                Total: {fmt(cartTotal)}
              </div>
              <Btn full onClick={completeSale} style={{ marginTop: 10 }}>
                Complete Sale
              </Btn>
            </>
          )}
        </div>
      </div>
    </>
  );
};
